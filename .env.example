# ============================================================
#  Sumber data World Cup 2026
# ============================================================
# Aplikasi bekerja TANPA API key (memakai fallback openfootball).
# Untuk data REALTIME (skor live), isi salah satu key di bawah.

# --- Opsi 1: football-data.org (GRATIS, direkomendasikan) ---
# Daftar gratis: https://www.football-data.org/client/register
# Kompetisi World Cup = kode "WC", limit 10 request/menit.
FOOTBALL_DATA_API_KEY=

# --- Opsi 2: API-Football via RapidAPI (opsional) ---
# https://www.api-football.com/  (free tier 100 req/hari)
API_FOOTBALL_KEY=

# Musim World Cup untuk API-Football (biasanya 2026)
API_FOOTBALL_SEASON=2026

# --- Video highlight (opsional; tanpa key pun tetap jalan lewat RSS FIFA) ---
# Urutan sumber: Highlightly -> YouTube Data API -> RSS channel FIFA.
# Highlightly (catatan: free tier TIDAK mencakup World Cup):
# https://rapidapi.com/highlightly-api-highlightly-api-default/api/football-highlights-api
HIGHLIGHTLY_API_KEY=

# YouTube Data API v3 — direkomendasikan, gratis (kuota 10.000 unit/hari).
# Buat key: https://console.cloud.google.com/apis/credentials
# (aktifkan "YouTube Data API v3" di library dulu)
YOUTUBE_API_KEY=
